// ============================================================
// TriageInsight — Prisma Schema
// Version: 1.0  |  Date: March 08, 2026
// Database: PostgreSQL + pgvector
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector]
}

// ============================================================
// ENUMS
// ============================================================

enum WorkspaceRole {
  ADMIN
  EDITOR
  VIEWER
}

enum FeedbackSource {
  PUBLIC_PORTAL
  EMAIL
  SLACK
  CSV_IMPORT
  VOICE_RECORDING
  MANUAL
  ZENDESK
  INTERCOM
}

enum FeedbackStatus {
  OPEN
  UNDER_CONSIDERATION
  PLANNED
  IN_PROGRESS
  SHIPPED
  DECLINED
  ARCHIVED
}

enum DuplicateSuggestionStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum RoadmapStatus {
  CONSIDERING
  PLANNED
  IN_PROGRESS
  SHIPPED
  DECLINED
}

enum IntegrationProvider {
  SLACK
  ZENDESK
  INTERCOM
}

enum AiJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AuditLogAction {
  USER_LOGIN
  USER_LOGOUT
  WORKSPACE_CREATED
  WORKSPACE_UPDATED
  WORKSPACE_DELETED
  MEMBER_INVITED
  MEMBER_ROLE_CHANGED
  MEMBER_REMOVED
  FEEDBACK_CREATED
  FEEDBACK_UPDATED
  FEEDBACK_DELETED
  FEEDBACK_MERGED
  THEME_CREATED
  THEME_UPDATED
  THEME_DELETED
  ROADMAP_ITEM_CREATED
  ROADMAP_ITEM_UPDATED
  ROADMAP_STATUS_UPDATED
  INTEGRATION_CONNECTED
  INTEGRATION_DISCONNECTED
  CUSTOMER_CREATED
  CUSTOMER_UPDATED
  CUSTOMER_DELETED
}

// ============================================================
// CORE MODELS
// ============================================================

/// Root tenant entity. All data is scoped to a Workspace.
model Workspace {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  logoAssetId String?   @unique
  plan        String    @default("free")
  stripeId    String?   @unique
  locale      String    @default("en")
  timezone    String    @default("UTC")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  memberships            WorkspaceMembership[]
  customers              Customer[]
  deals                  Deal[]
  feedbackItems          FeedbackItem[]
  themes                 Theme[]
  roadmapItems           RoadmapItem[]
  supportTickets         SupportTicket[]
  supportIssueClusters   SupportIssueCluster[]
  issueSpikeEvents       IssueSpikeEvent[]
  integrationConnections IntegrationConnection[]
  uploadAssets           UploadAsset[]
  aiJobLogs              AiJobLog[]
  auditLogs              AuditLog[]
  digestSubscriptions    DigestSubscription[]
  logoAsset              UploadAsset?            @relation("WorkspaceLogo", fields: [logoAssetId], references: [id])
}

/// A platform user. Can belong to multiple workspaces.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  googleId      String?   @unique
  avatarAssetId String?   @unique
  locale        String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  memberships         WorkspaceMembership[]
  submittedFeedback   FeedbackItem[]
  feedbackVotes       FeedbackVote[]
  feedbackComments    FeedbackComment[]
  digestSubscriptions DigestSubscription[]
  auditLogs           AuditLog[]
  avatarAsset         UploadAsset?          @relation("UserAvatar", fields: [avatarAssetId], references: [id])
}

/// Join table linking Users to Workspaces with a role.
model WorkspaceMembership {
  id          String        @id @default(cuid())
  userId      String
  workspaceId String
  role        WorkspaceRole @default(EDITOR)
  invitedAt   DateTime?
  joinedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
}

// ============================================================
// FEEDBACK INTELLIGENCE — PHASE 1
// ============================================================

/// An end-customer of the workspace's product.
model Customer {
  id          String    @id @default(cuid())
  workspaceId String
  name        String?
  email       String?
  company     String?
  arr         Int       @default(0)   // Annual Recurring Revenue in USD cents
  segment     String?                 // e.g., "Enterprise", "SMB", "Startup"
  externalId  String?                 // ID from CRM or external system
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?               // Soft delete

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deals     Deal[]
  signals   CustomerSignal[]

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([deletedAt])
  @@index([segment])
}

/// A revenue deal linked to a customer, used for revenue-weighted prioritisation.
model Deal {
  id          String    @id @default(cuid())
  workspaceId String
  customerId  String
  name        String
  value       Int                     // Deal value in USD cents
  stage       String                  // e.g., "Open", "Won", "Lost"
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer  Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([customerId])
  @@index([stage])
}

/// A single piece of customer feedback from any source.
model FeedbackItem {
  id            String         @id @default(cuid())
  workspaceId   String
  title         String
  content       String?
  source        FeedbackSource
  status        FeedbackStatus @default(OPEN)
  submittedById String?
  aiSummary     String?        // AI-generated one-sentence summary
  embedding     Unsupported("vector(1536)")?  // OpenAI text-embedding-3-small
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?      // Soft delete

  workspace              Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  submittedBy            User?                 @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  votes                  FeedbackVote[]
  comments               FeedbackComment[]
  signals                CustomerSignal[]
  duplicateSuggestions   DuplicateSuggestion[] @relation("OriginalFeedback")
  duplicateOfSuggestions DuplicateSuggestion[] @relation("DuplicateFeedback")
  mergedInto             FeedbackMerge[]       @relation("MergedFeedback")
  mergedFrom             FeedbackMerge[]       @relation("SourceFeedback")
  themes                 ThemeFeedbackMap[]

  @@index([workspaceId])
  @@index([submittedById])
  @@index([status])
  @@index([source])
  @@index([deletedAt])
  // NOTE: After migration, add pgvector index manually:
  // CREATE INDEX ON "FeedbackItem" USING ivfflat (embedding vector_cosine_ops) WITH (lists = 100);
}

/// A vote cast by a user on a feedback item (upvote).
model FeedbackVote {
  id             String   @id @default(cuid())
  feedbackItemId String
  userId         String
  createdAt      DateTime @default(now())

  feedbackItem FeedbackItem @relation(fields: [feedbackItemId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([feedbackItemId, userId])
  @@index([feedbackItemId])
  @@index([userId])
}

/// A comment left by a user on a feedback item.
model FeedbackComment {
  id             String   @id @default(cuid())
  feedbackItemId String
  userId         String
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  feedbackItem FeedbackItem @relation(fields: [feedbackItemId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([feedbackItemId])
  @@index([userId])
}

/// An AI-suggested pair of duplicate feedback items awaiting user review.
model DuplicateSuggestion {
  id                  String                    @id @default(cuid())
  originalFeedbackId  String
  duplicateFeedbackId String
  similarityScore     Float                     // Cosine similarity score (0.0 – 1.0)
  status              DuplicateSuggestionStatus @default(PENDING)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  originalFeedback  FeedbackItem @relation("OriginalFeedback",  fields: [originalFeedbackId],  references: [id], onDelete: Cascade)
  duplicateFeedback FeedbackItem @relation("DuplicateFeedback", fields: [duplicateFeedbackId], references: [id], onDelete: Cascade)

  @@unique([originalFeedbackId, duplicateFeedbackId])
  @@index([status])
  @@index([originalFeedbackId])
}

/// Records the merge of one feedback item into another (the canonical item).
model FeedbackMerge {
  id               String   @id @default(cuid())
  sourceFeedbackId String   @unique // The item that was merged away
  mergedFeedbackId String           // The canonical item it was merged into
  mergedAt         DateTime @default(now())

  sourceFeedback FeedbackItem @relation("SourceFeedback", fields: [sourceFeedbackId], references: [id], onDelete: Cascade)
  mergedFeedback FeedbackItem @relation("MergedFeedback", fields: [mergedFeedbackId], references: [id], onDelete: Cascade)

  @@index([mergedFeedbackId])
}

/// An AI-generated cluster of related feedback items.
model Theme {
  id            String    @id @default(cuid())
  workspaceId   String
  title         String
  summary       String?   // AI-generated one-sentence summary
  priorityScore Float     @default(0)  // Calculated from ARR + vote count
  totalArr      Int       @default(0)  // Sum of ARR of linked customers
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // Soft delete

  workspace     Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedbackItems ThemeFeedbackMap[]
  roadmapItems  RoadmapThemeMap[]

  @@index([workspaceId])
  @@index([deletedAt])
  @@index([priorityScore])
}

/// Join table linking Themes to FeedbackItems (many-to-many).
model ThemeFeedbackMap {
  themeId        String
  feedbackItemId String

  theme        Theme        @relation(fields: [themeId],        references: [id], onDelete: Cascade)
  feedbackItem FeedbackItem @relation(fields: [feedbackItemId], references: [id], onDelete: Cascade)

  @@id([themeId, feedbackItemId])
  @@index([feedbackItemId])
}

/// A signal linking a customer to a feedback item or support ticket.
/// Used to calculate revenue impact and customer influence.
model CustomerSignal {
  id              String   @id @default(cuid())
  customerId      String
  feedbackItemId  String?
  supportTicketId String?
  createdAt       DateTime @default(now())

  customer      Customer       @relation(fields: [customerId],     references: [id], onDelete: Cascade)
  feedbackItem  FeedbackItem?  @relation(fields: [feedbackItemId], references: [id], onDelete: SetNull)
  supportTicket SupportTicket? @relation(fields: [supportTicketId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([feedbackItemId])
  @@index([supportTicketId])
}

/// A product roadmap item, typically derived from one or more themes.
model RoadmapItem {
  id          String        @id @default(cuid())
  workspaceId String
  title       String
  description String?
  status      RoadmapStatus @default(CONSIDERING)
  targetDate  DateTime?
  isPublic    Boolean       @default(true)  // Visible on public roadmap
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  themes    RoadmapThemeMap[]

  @@index([workspaceId])
  @@index([status])
}

/// Join table linking RoadmapItems to Themes (many-to-many).
model RoadmapThemeMap {
  roadmapItemId String
  themeId       String

  roadmapItem RoadmapItem @relation(fields: [roadmapItemId], references: [id], onDelete: Cascade)
  theme       Theme       @relation(fields: [themeId],       references: [id], onDelete: Cascade)

  @@id([roadmapItemId, themeId])
  @@index([themeId])
}

// ============================================================
// SUPPORT INTELLIGENCE — PHASE 2
// ============================================================

/// A support ticket ingested from Zendesk, Intercom, or other sources.
model SupportTicket {
  id          String         @id @default(cuid())
  workspaceId String
  externalId  String         // Native ID from Zendesk / Intercom
  subject     String
  content     String
  source      FeedbackSource // ZENDESK or INTERCOM
  embedding   Unsupported("vector(1536)")?  // OpenAI text-embedding-3-small
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signals   CustomerSignal[]
  clusters  SupportIssueClusterMap[]

  @@unique([workspaceId, externalId, source])
  @@index([workspaceId])
  @@index([source])
  // NOTE: After migration, add pgvector index manually:
  // CREATE INDEX ON "SupportTicket" USING ivfflat (embedding vector_cosine_ops) WITH (lists = 100);
}

/// An AI-generated cluster of semantically related support tickets.
model SupportIssueCluster {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tickets   SupportIssueClusterMap[]
  spikes    IssueSpikeEvent[]

  @@index([workspaceId])
}

/// Join table linking SupportIssueClusters to SupportTickets (many-to-many).
model SupportIssueClusterMap {
  clusterId String
  ticketId  String

  cluster SupportIssueCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  ticket  SupportTicket       @relation(fields: [ticketId],  references: [id], onDelete: Cascade)

  @@id([clusterId, ticketId])
  @@index([ticketId])
}

/// An event representing an abnormal spike in support ticket volume for a cluster.
model IssueSpikeEvent {
  id          String   @id @default(cuid())
  workspaceId String
  clusterId   String
  ticketCount Int      // Number of tickets in the spike window
  startedAt   DateTime
  endedAt     DateTime
  createdAt   DateTime @default(now())

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cluster   SupportIssueCluster @relation(fields: [clusterId],   references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([clusterId])
  @@index([startedAt])
}

// ============================================================
// PLATFORM & SYSTEM MODELS
// ============================================================

/// A user's subscription to the weekly insight digest email.
model DigestSubscription {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  frequency   String   @default("weekly") // "weekly" | "daily"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId],      references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

/// A configured connection to a third-party integration (Slack, Zendesk, Intercom).
model IntegrationConnection {
  id          String              @id @default(cuid())
  workspaceId String
  provider    IntegrationProvider
  accessToken String?             // Encrypted at rest
  refreshToken String?            // Encrypted at rest
  config      Json?               // Provider-specific configuration
  connectedAt DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

/// A file uploaded to S3 (voice recordings, CSV imports, avatars, logos).
model UploadAsset {
  id          String   @id @default(cuid())
  workspaceId String
  s3Key       String   @unique
  filename    String
  contentType String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  workspace     Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userAvatar    User?      @relation("UserAvatar")
  workspaceLogo Workspace? @relation("WorkspaceLogo")

  @@index([workspaceId])
}

/// A log entry for an asynchronous AI job (deduplication, clustering, summarisation).
model AiJobLog {
  id          String      @id @default(cuid())
  workspaceId String
  jobName     String      // e.g., "generate-embedding", "cluster-themes"
  status      AiJobStatus @default(PENDING)
  payload     Json?       // Input data for the job
  result      Json?       // Output data from the job
  error       String?     // Error message if the job failed
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([jobName, status])
  @@index([createdAt])
}

/// An immutable audit log entry for security and compliance tracking.
model AuditLog {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String?        // Null for system-triggered actions
  action      AuditLogAction
  entityType  String?        // e.g., "FeedbackItem", "Theme"
  entityId    String?        // ID of the affected entity
  details     Json?          // Additional context (e.g., before/after values)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId],      references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}
