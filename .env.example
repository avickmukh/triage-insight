# TriageInsight Environment Variables
#
# This file documents all environment variables required by the API and worker
# applications. Copy this file to .env and fill in the values for your
# local development environment.

# ─── Application Settings ───────────────────────────────────────────────────

# Environment mode: development, production, or test
NODE_ENV=development

# Port the API server will listen on
PORT=3000

# ─── Required ───────────────────────────────────────────────────────────────

# PostgreSQL connection URL (includes user, password, host, port, and database)
# Example: postgresql://user:password@localhost:5432/triageinsight?schema=public
DATABASE_URL=

# Secret key for signing JWTs (must be at least 32 characters long)
# Generate a secure random string, e.g., with `openssl rand -hex 32`
JWT_SECRET=

# ─── CORS ───────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for CORS requests
# In development, this can be http://localhost:3001 (the web app default)
# In production, set this to your frontend application URL(s)
CORS_ORIGIN=http://localhost:3001

# ─── Rate Limiting ──────────────────────────────────────────────────────────

# Max requests per IP per THROTTLE_TTL_MS (milliseconds)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ─── Redis / Bull Queues ────────────────────────────────────────────────────

# Connection details for Redis, used by BullMQ for background job processing.
# The worker will not run without a valid Redis connection.
#
# Option A — explicit vars (recommended for local dev and Docker):
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=           # Required for Upstash, Redis Cloud, etc.
# REDIS_TLS=false           # Set to "true" for TLS-enabled Redis (cloud providers)
#
# Option B — single URL (takes priority over the vars above if set):
# REDIS_URL=redis://:password@host:port
# REDIS_URL=rediss://:password@host:port  # rediss:// enables TLS automatically

# ─── AWS S3 File Uploads ────────────────────────────────────────────────────

# S3 bucket and credentials for file uploads (e.g., feedback attachments)
# If not configured, file upload endpoints will be disabled.
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── OpenAI ─────────────────────────────────────────────────────────────────

# API key for OpenAI, used for all AI-powered features (summarization, clustering, etc.)
# If not configured, AI features will be disabled.
OPENAI_API_KEY=

# ─── Email ──────────────────────────────────────────────────────────────────

# Email delivery provider: console, smtp, or ses
# - console: Logs emails to the console (default)
# - smtp: Sends emails via an SMTP server (requires SMTP_* variables below)
# - ses: Sends emails via AWS SES (requires AWS credentials with SES permissions)
EMAIL_PROVIDER=console

# SMTP settings (only required if EMAIL_PROVIDER=smtp)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_ADDRESS=

# ─── Stripe Billing ─────────────────────────────────────────────────────────

# Stripe API keys for billing and subscription management
# If not configured, billing and plan management features will be disabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Job Tuning ─────────────────────────────────────────────────────────────

# BullMQ job processing options
JOB_MAX_ATTEMPTS=5
JOB_BACKOFF_DELAY_MS=2000
JOB_REMOVE_ON_COMPLETE=1000
JOB_REMOVE_ON_FAIL=5000
