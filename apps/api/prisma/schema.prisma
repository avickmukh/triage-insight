generator client {
  previewFeatures = ["postgresqlExtensions"]
  provider        = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector]
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum FeedbackStatus {
  NEW
  IN_REVIEW
  PROCESSED
  ARCHIVED
  MERGED
}

enum FeedbackSourceType {
  MANUAL
  PUBLIC_PORTAL
  EMAIL
  SLACK
  CSV_IMPORT
  VOICE
}

enum AuditLogAction {
  FEEDBACK_MERGE
  FEEDBACK_STATUS_CHANGE
  FEEDBACK_UPDATE
  THEME_CREATE
  THEME_UPDATE
  THEME_DELETE
  THEME_MERGE
  THEME_SPLIT
  THEME_FEEDBACK_ADD
  THEME_FEEDBACK_REMOVE
  PRIORITIZATION_SETTINGS_UPDATE
  ROADMAP_ITEM_CREATE
  ROADMAP_ITEM_UPDATE
  ROADMAP_ITEM_STATUS_CHANGE
}

enum ThemeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum RoadmapStatus {
  EXPLORING
  PLANNED
  COMMITTED
  SHIPPED
}

enum IntegrationProvider {
  ZENDESK
  INTERCOM
  FRESHDESK
}

enum SupportTicketStatus {
  OPEN
  PENDING
  SOLVED
  CLOSED
}

// ─── Auth Models ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   WorkspaceMember[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
}

model Workspace {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members                WorkspaceMember[]
  feedbacks              Feedback[]
  themes                 Theme[]
  auditLogs              AuditLog[]
  prioritizationSettings PrioritizationSettings?
  roadmapItems           RoadmapItem[]
  integrationConnections IntegrationConnection[]
  supportTickets         SupportTicket[]
  supportIssueClusters   SupportIssueCluster[]
  issueSpikeEvents       IssueSpikeEvent[]
}

model WorkspaceMember {
  id          String   @id @default(uuid())
  role        Role     @default(VIEWER)
  joinedAt    DateTime @default(now())
  userId      String
  workspaceId String

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Feedback & AI Models ─────────────────────────────────────────────────────

model Feedback {
  id             String   @id @default(uuid())
  title          String
  description    String
  normalizedText String?
  language       String?
  summary        String?
  status         FeedbackStatus
  sourceType     FeedbackSourceType
  customerId     String?
  workspaceId    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  embedding Unsupported("vector(1536)")?

  mergedIntoId String?
  mergedInto   Feedback?  @relation("FeedbackMerge", fields: [mergedIntoId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  mergedFrom   Feedback[] @relation("FeedbackMerge")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attachments FeedbackAttachment[]
  themes      ThemeFeedback[]

  duplicateSuggestionsAsSource FeedbackDuplicateSuggestion[] @relation("SourceFeedback")
  duplicateSuggestionsAsTarget FeedbackDuplicateSuggestion[] @relation("TargetFeedback")

  @@index([workspaceId])
  @@index([status])
  @@index([sourceType])
  @@index([customerId])
  @@index([createdAt])
}

model FeedbackAttachment {
  id         String   @id @default(uuid())
  feedbackId String
  fileName   String
  s3Key      String
  s3Bucket   String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

model FeedbackDuplicateSuggestion {
  id         String   @id @default(uuid())
  sourceId   String
  targetId   String
  similarity Float
  createdAt  DateTime @default(now())

  sourceFeedback Feedback @relation("SourceFeedback", fields: [sourceId], references: [id], onDelete: Cascade)
  targetFeedback Feedback @relation("TargetFeedback", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
}

// ─── Theme Models ─────────────────────────────────────────────────────────────

model Theme {
  id          String      @id @default(uuid())
  workspaceId String
  title       String
  description String?
  status      ThemeStatus @default(DRAFT)
  pinned      Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedbacks    ThemeFeedback[]
  roadmapItems RoadmapItem[]
  correlations SupportIssueCluster[] @relation("ClusterTheme")

  @@index([workspaceId])
  @@index([status])
  @@index([pinned])
}

model ThemeFeedback {
  themeId    String
  feedbackId String
  assignedAt DateTime @default(now())

  theme    Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@id([themeId, feedbackId])
}

// ─── Roadmap Models ───────────────────────────────────────────────────────────

model RoadmapItem {
  id          String        @id @default(uuid())
  workspaceId String
  themeId     String?
  title       String
  description String?
  status      RoadmapStatus @default(EXPLORING)
  isPublic    Boolean       @default(false)

  priorityScore      Float?
  revenueImpactValue Float?
  dealInfluenceValue Float?
  customerCount      Int?

  targetQuarter String?
  targetYear    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  theme     Theme?    @relation(fields: [themeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
  @@index([isPublic])
  @@index([themeId])
}

// ─── Prioritization Models ────────────────────────────────────────────────────

model PrioritizationSettings {
  workspaceId String @id

  requestFrequencyWeight Float @default(0.2)
  customerCountWeight    Float @default(0.2)
  arrValueWeight         Float @default(0.2)
  accountPriorityWeight  Float @default(0.1)
  dealValueWeight        Float @default(0.2)
  strategicWeight        Float @default(0.1)

  dealStageProspecting Float @default(0.1)
  dealStageQualifying  Float @default(0.3)
  dealStageProposal    Float @default(0.6)
  dealStageNegotiation Float @default(0.8)
  dealStageClosedWon   Float @default(1.0)

  updatedAt DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── Support Intelligence Models ─────────────────────────────────────────────

model IntegrationConnection {
  id           String              @id @default(uuid())
  workspaceId  String
  provider     IntegrationProvider
  accessToken  String
  refreshToken String?
  subdomain    String?
  metadata     Json?
  lastSyncedAt DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

model SupportTicket {
  id             String              @id @default(uuid())
  workspaceId    String
  externalId     String
  provider       IntegrationProvider
  subject        String
  description    String?
  status         SupportTicketStatus @default(OPEN)
  customerId     String?
  customerEmail  String?
  tags           String[]
  arrValue       Float?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  externalCreatedAt DateTime?

  embedding Unsupported("vector(1536)")?

  workspace    Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  clusterMaps  SupportIssueClusterMap[]

  @@unique([workspaceId, provider, externalId])
  @@index([workspaceId])
  @@index([status])
  @@index([customerId])
  @@index([externalCreatedAt])
}

model SupportIssueCluster {
  id          String   @id @default(uuid())
  workspaceId String
  title       String
  description String?
  themeId     String?
  ticketCount Int      @default(0)
  arrExposure Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  theme       Theme?                   @relation("ClusterTheme", fields: [themeId], references: [id], onDelete: SetNull)
  ticketMaps  SupportIssueClusterMap[]
  spikeEvents IssueSpikeEvent[]

  @@index([workspaceId])
  @@index([themeId])
}

model SupportIssueClusterMap {
  clusterId String
  ticketId  String
  score     Float    @default(0)
  createdAt DateTime @default(now())

  cluster SupportIssueCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  ticket  SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([clusterId, ticketId])
}

model IssueSpikeEvent {
  id          String   @id @default(uuid())
  workspaceId String
  clusterId   String
  windowStart DateTime
  windowEnd   DateTime
  ticketCount Int
  baseline    Float
  zScore      Float
  createdAt   DateTime @default(now())

  workspace Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cluster   SupportIssueCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([clusterId])
  @@index([windowStart])
}

// ─── System Models ────────────────────────────────────────────────────────────

model AuditLog {
  id          String         @id @default(uuid())
  workspaceId String
  userId      String
  action      AuditLogAction
  details     Json
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
