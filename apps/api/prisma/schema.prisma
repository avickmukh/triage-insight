generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector(map: "vector")]
}

//
// ENUMS
//

enum PlatformRole {
  SUPER_ADMIN
  ADMIN
}

enum WorkspaceRole {
  ADMIN
  EDITOR
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum WorkspaceStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DISABLED
}

enum BillingPlan {
  FREE
  PRO
  BUSINESS
}

enum TrialStatus {
  ACTIVE
  EXPIRED
  CONVERTED
}

enum PlanStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum BillingStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
}

enum FeedbackStatus {
  NEW
  IN_REVIEW
  PROCESSED
  ARCHIVED
  MERGED
}

enum FeedbackSourceType {
  MANUAL
  PUBLIC_PORTAL
  EMAIL
  SLACK
  CSV_IMPORT
  VOICE
  API
}

enum DuplicateSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ThemeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RoadmapStatus {
  BACKLOG
  EXPLORING
  PLANNED
  COMMITTED
  SHIPPED
}

enum IntegrationProvider {
  ZENDESK
  INTERCOM
  FRESHDESK
  SLACK
  EMAIL
  HUBSPOT
  SALESFORCE
  STRIPE
}

enum SupportTicketStatus {
  OPEN
  PENDING
  SOLVED
  CLOSED
}

enum DealStage {
  PROSPECTING
  QUALIFYING
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum CustomerSegment {
  SMB
  MID_MARKET
  ENTERPRISE
}

enum AccountPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CustomerLifecycleStage {
  LEAD
  PROSPECT
  ACTIVE
  EXPANDING
  AT_RISK
  CHURNED
}

enum ChurnRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditLogAction {
  USER_INVITED
  MEMBER_ROLE_CHANGED
  WORKSPACE_CREATED
  WORKSPACE_STATUS_CHANGED
  BILLING_UPDATED
  FEEDBACK_CREATE
  FEEDBACK_UPDATE
  FEEDBACK_STATUS_CHANGE
  FEEDBACK_MERGE
  DUPLICATE_DECISION
  THEME_CREATE
  THEME_UPDATE
  THEME_DELETE
  THEME_MERGE
  THEME_SPLIT
  THEME_FEEDBACK_ADD
  THEME_FEEDBACK_REMOVE
  PRIORITIZATION_SETTINGS_UPDATE
  ROADMAP_ITEM_CREATE
  ROADMAP_ITEM_UPDATE
  ROADMAP_ITEM_STATUS_CHANGE
  INTEGRATION_CONNECTED
  INTEGRATION_SYNC
  SUPPORT_CLUSTER_CREATED
  SUPPORT_SPIKE_DETECTED
  DIGEST_SENT
  VOICE_PROCESSED
  CHURN_SCORE_UPDATED
}

enum DigestFrequency {
  WEEKLY
  MONTHLY
}

enum AiJobType {
  FEEDBACK_SUMMARY
  FEEDBACK_DUPLICATE_DETECTION
  THEME_CLUSTERING
  VOICE_TRANSCRIPTION
  VOICE_EXTRACTION
  SUPPORT_CLUSTERING
  SUPPORT_CORRELATION
  CHURN_SCORING
}

enum AiJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
}

enum PublicPortalVisibility {
  PUBLIC
  PRIVATE
}

enum DomainVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  FAILED
}

//
// PLATFORM / AUTH
//

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  passwordHash        String
  firstName           String
  lastName            String
  platformRole        PlatformRole?
  status              UserStatus           @default(ACTIVE)
  locale              String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  memberships         WorkspaceMember[]
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  feedbackVotes       FeedbackVote[]
  feedbackComments    FeedbackComment[]
  digestSubscriptions DigestSubscription[]
  invitesSent         WorkspaceInvite[]   @relation("InvitedByUser")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  userId     String
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

//
// WORKSPACE / BILLING / SAAS CONTROL
//

model Workspace {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String                 @unique
  description           String?
  status                WorkspaceStatus        @default(PENDING)
  timezone              String                 @default("UTC")
  defaultLocale         String                 @default("en")
  defaultCurrency       String                 @default("USD")
  portalVisibility      PublicPortalVisibility @default(PUBLIC)

  billingPlan           BillingPlan            @default(FREE)
  billingStatus         BillingStatus          @default(TRIALING)
  billingEmail          String?
  stripeCustomerId      String?                @unique
  stripeSubscriptionId  String?                @unique
  trialEndsAt           DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  /// Trial lifecycle fields
  trialStartedAt        DateTime?
  trialStatus           TrialStatus            @default(ACTIVE)
  planStatus            PlanStatus             @default(ACTIVE)
  /// Plan limits (overridable per workspace; defaults come from Plan config)
  seatLimit             Int                    @default(3)
  aiUsageLimit          Int                    @default(0)
  /// FK to the Plan config row that governs this workspace
  planId                String?

  /// Custom domain set by the workspace admin (e.g. "feedback.acme.com")
  customDomain             String?                      @unique
  /// Current DNS verification state
  domainVerificationStatus DomainVerificationStatus     @default(UNVERIFIED)
  /// TXT record challenge value the admin must add to their DNS
  domainVerificationToken  String?
  /// Timestamp of the last verification attempt
  domainLastCheckedAt      DateTime?

  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  members               WorkspaceMember[]
  customers             Customer[]
  deals                 Deal[]
  feedbacks             Feedback[]
  feedbackAttachments   FeedbackAttachment[]
  feedbackVotes         FeedbackVote[]
  feedbackComments      FeedbackComment[]
  themes                Theme[]
  roadmapItems          RoadmapItem[]
  supportTickets        SupportTicket[]
  supportIssueClusters  SupportIssueCluster[]
  issueSpikeEvents      IssueSpikeEvent[]
  integrationConnections IntegrationConnection[]
  prioritizationSettings PrioritizationSettings?
  digestSubscriptions   DigestSubscription[]
  digestRuns            DigestRun[]
  auditLogs             AuditLog[]
  uploadAssets          UploadAsset[]
  aiJobLogs             AiJobLog[]
  usageMetrics          UsageMetric[]
  churnScores           CustomerChurnScore[]
  portalUsers           PortalUser[]
  invites               WorkspaceInvite[]
  customerSignals       CustomerSignal[]
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  role        WorkspaceRole @default(VIEWER)
  /// Job title / position of this member within the workspace (e.g. "Support Lead")
  position    String?
  joinedAt    DateTime      @default(now())
  userId      String
  workspaceId String

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([userId])
}

model UsageMetric {
  id          String   @id @default(uuid())
  workspaceId String
  metricKey   String
  metricValue Float    @default(0)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([metricKey])
  @@index([periodStart])
}

//
// CUSTOMER / REVENUE CONTEXT
//

model Customer {
  id               String                  @id @default(uuid())
  workspaceId      String
  name             String
  companyName      String?
  email            String?
  segment          CustomerSegment?
  arrValue         Float?                  @default(0)
  currency         String?                 @default("USD")
  accountPriority  AccountPriority         @default(MEDIUM)
  lifecycleStage   CustomerLifecycleStage  @default(PROSPECT)
  locale           String?
  countryCode      String?
  externalRef      String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  workspace        Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedbacks        Feedback[]
  supportTickets   SupportTicket[]
  deals            Deal[]
  signals          CustomerSignal[]
  churnScores      CustomerChurnScore[]
  portalUsers      PortalUser[]

  @@index([workspaceId])
  @@index([email])
  @@index([companyName])
  @@index([arrValue])
  @@index([accountPriority])
}

model Deal {
  id          String     @id @default(uuid())
  workspaceId String
  customerId  String
  title       String
  annualValue Float      @default(0)
  currency    String     @default("USD")
  stage       DealStage
  status      DealStatus @default(OPEN)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer    Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  themeLinks  DealThemeLink[]

  @@index([workspaceId])
  @@index([customerId])
  @@index([stage])
  @@index([status])
}

model DealThemeLink {
  dealId      String
  themeId     String
  createdAt   DateTime @default(now())

  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  theme       Theme     @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([dealId, themeId])
  @@index([themeId])
}

//
// PUBLIC PORTAL IDENTITIES
//

model PortalUser {
  id              String    @id @default(uuid())
  workspaceId      String
  customerId       String?
  email           String?
  name            String?
  passwordHash    String?
  verified        Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  feedbacks        Feedback[]
  feedbackVotes   FeedbackVote[]
  feedbackComments FeedbackComment[]

  @@index([workspaceId])
  @@index([customerId])
  @@index([email])
  @@unique([workspaceId, email])
}

//
// FEEDBACK / PUBLIC PORTAL / AI
//

model Feedback {
  id              String              @id @default(uuid())
  workspaceId      String
  customerId       String?
  /// PortalUser who submitted this feedback (null for internal/CSV/Slack/API sources)
  portalUserId    String?
  sourceType      FeedbackSourceType
  sourceRef       String?
  title           String
  description     String
  /// Original unmodified text captured before any normalization
  rawText         String?
  normalizedText  String?
  language        String?
  summary         String?
  status          FeedbackStatus      @default(NEW)
  sentiment       Float?
  impactScore     Float?
  /// Arbitrary source-specific metadata (e.g. Slack channel, email headers, CSV row index)
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  submittedAt     DateTime            @default(now())

  embedding       Unsupported("vector(1536)")?

  mergedIntoId    String?
  mergedInto      Feedback?           @relation("FeedbackMergeRelation", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom      Feedback[]          @relation("FeedbackMergeRelation")

  workspace       Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer        Customer?           @relation(fields: [customerId], references: [id], onDelete: SetNull)
  portalUser      PortalUser?         @relation(fields: [portalUserId], references: [id], onDelete: SetNull)

  attachments     FeedbackAttachment[]
  comments        FeedbackComment[]
  votes           FeedbackVote[]
  themes          ThemeFeedback[]

  duplicateSuggestionsAsSource FeedbackDuplicateSuggestion[] @relation("SourceFeedback")
  duplicateSuggestionsAsTarget FeedbackDuplicateSuggestion[] @relation("TargetFeedback")

  @@index([workspaceId])
  @@index([customerId])
  @@index([portalUserId])
  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
  @@index([submittedAt])
}

model FeedbackAttachment {
  id             String   @id @default(uuid())
  workspaceId     String
  feedbackId     String
  fileName       String
  s3Key          String
  s3Bucket       String
  mimeType       String
  sizeBytes      Int
  createdAt      DateTime @default(now())

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedback       Feedback  @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([feedbackId])
}

model FeedbackVote {
  id             String   @id @default(uuid())
  workspaceId     String
  feedbackId     String
  userId         String?
  portalUserId   String?
  anonymousId    String?
  createdAt      DateTime @default(now())

  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedback       Feedback   @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  portalUser     PortalUser? @relation(fields: [portalUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([feedbackId])
  @@index([userId])
  @@index([portalUserId])
  @@index([anonymousId])
}

model FeedbackComment {
  id             String    @id @default(uuid())
  workspaceId     String
  feedbackId     String
  userId         String?
  portalUserId   String?
  anonymousId    String?
  authorName     String?
  authorEmail    String?
  body           String
  createdAt      DateTime  @default(now())

  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedback       Feedback   @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  portalUser     PortalUser? @relation(fields: [portalUserId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([feedbackId])
  @@index([userId])
  @@index([portalUserId])
  @@index([anonymousId])
}

model FeedbackDuplicateSuggestion {
  id            String                     @id @default(uuid())
  sourceId      String
  targetId      String
  similarity    Float
  status        DuplicateSuggestionStatus  @default(PENDING)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  sourceFeedback Feedback @relation("SourceFeedback", fields: [sourceId], references: [id], onDelete: Cascade)
  targetFeedback Feedback @relation("TargetFeedback", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
  @@index([status])
}

//
// THEMES
//

model Theme {
  id               String               @id @default(uuid())
  workspaceId      String
  title            String
  description      String?
  status           ThemeStatus          @default(DRAFT)
  pinned           Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  workspace        Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  feedbacks        ThemeFeedback[]
  roadmapItems     RoadmapItem[]
  correlations     SupportIssueCluster[] @relation("ClusterTheme")
  dealLinks        DealThemeLink[]
  customerSignals  CustomerSignal[]

  @@index([workspaceId])
  @@index([status])
  @@index([pinned])
}

model ThemeFeedback {
  themeId          String
  feedbackId       String
  assignedAt       DateTime @default(now())
  /// Source of assignment: "manual" (by a user) or "ai" (by the clustering pipeline)
  assignedBy       String   @default("manual")
  /// AI similarity confidence score (0–1); null for manual assignments
  confidence       Float?

  theme            Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  feedback         Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@id([themeId, feedbackId])
  @@index([feedbackId])
  @@index([assignedBy])
}

model CustomerSignal {
  id               String    @id @default(uuid())
  workspaceId      String
  customerId       String
  themeId          String?
  signalType       String
  sourceId         String?
  strength         Float     @default(0)
  createdAt        DateTime  @default(now())

  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  theme            Theme?    @relation(fields: [themeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([customerId])
  @@index([themeId])
  @@index([signalType])
}

//
// ROADMAP
//

model RoadmapItem {
  id                String        @id @default(uuid())
  workspaceId       String
  themeId           String?
  title             String
  description       String?
  status            RoadmapStatus @default(EXPLORING)
  isPublic          Boolean       @default(false)

  priorityScore      Float?
  /// 0–1: AI confidence in the priority score (null = not yet computed)
  confidenceScore    Float?
  /// Normalised 0–100 revenue impact score derived from ARR signals
  revenueImpactScore Float?
  /// Cached count of CustomerSignal rows linked via the theme
  signalCount        Int      @default(0)
  revenueImpactValue Float?
  dealInfluenceValue Float?
  customerCount      Int?

  targetQuarter      String?
  targetYear         Int?
  targetDate         DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  theme              Theme?    @relation(fields: [themeId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
  @@index([isPublic])
  @@index([themeId])
}

//
// PRIORITIZATION
//

model PrioritizationSettings {
  workspaceId               String @id

  requestFrequencyWeight    Float @default(0.2)
  customerCountWeight       Float @default(0.2)
  arrValueWeight            Float @default(0.2)
  accountPriorityWeight     Float @default(0.1)
  dealValueWeight           Float @default(0.2)
  strategicWeight           Float @default(0.1)

  dealStageProspecting      Float @default(0.1)
  dealStageQualifying       Float @default(0.3)
  dealStageProposal         Float @default(0.6)
  dealStageNegotiation      Float @default(0.8)
  dealStageClosedWon        Float @default(1.0)

  updatedAt                 DateTime @updatedAt

  workspace                 Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

//
// SUPPORT INTELLIGENCE
//

model IntegrationConnection {
  id                String              @id @default(uuid())
  workspaceId       String
  provider          IntegrationProvider
  accessToken       String
  refreshToken      String?
  subdomain         String?
  metadata          Json?
  lastSyncedAt      DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@index([workspaceId])
}

model SupportTicket {
  id                String              @id @default(uuid())
  workspaceId       String
  customerId        String?
  externalId        String
  provider          IntegrationProvider
  subject           String
  description       String?
  status            SupportTicketStatus @default(OPEN)
  customerEmail     String?
  tags              String[]
  arrValue          Float?
  externalCreatedAt DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  embedding         Unsupported("vector(1536)")?

  workspace         Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer          Customer?                @relation(fields: [customerId], references: [id], onDelete: SetNull)
  clusterMaps       SupportIssueClusterMap[]

  @@unique([workspaceId, provider, externalId])
  @@index([workspaceId])
  @@index([customerId])
  @@index([status])
  @@index([externalCreatedAt])
}

model SupportIssueCluster {
  id                String   @id @default(uuid())
  workspaceId       String
  title             String
  description       String?
  themeId           String?
  ticketCount       Int      @default(0)
  arrExposure       Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace         Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  theme             Theme?                    @relation("ClusterTheme", fields: [themeId], references: [id], onDelete: SetNull)
  ticketMaps        SupportIssueClusterMap[]
  spikeEvents       IssueSpikeEvent[]

  @@index([workspaceId])
  @@index([themeId])
}

model SupportIssueClusterMap {
  clusterId         String
  ticketId          String
  score             Float    @default(0)
  createdAt         DateTime @default(now())

  cluster           SupportIssueCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  ticket            SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([clusterId, ticketId])
  @@index([ticketId])
}

model IssueSpikeEvent {
  id                String   @id @default(uuid())
  workspaceId       String
  clusterId         String
  windowStart       DateTime
  windowEnd         DateTime
  ticketCount       Int
  baseline          Float
  zScore            Float
  createdAt         DateTime @default(now())

  workspace         Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  cluster           SupportIssueCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([clusterId])
  @@index([windowStart])
}

//
// FUTURE CHURN INTELLIGENCE
//

model CustomerChurnScore {
  id                String          @id @default(uuid())
  workspaceId       String
  customerId        String
  score             Float
  riskLevel         ChurnRiskLevel
  reasons           Json?
  calculatedAt      DateTime        @default(now())

  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer          Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([customerId])
  @@index([riskLevel])
  @@index([calculatedAt])
}

//
// DIGEST / SYSTEM / AUDIT / UPLOADS
//

model DigestSubscription {
  id                String           @id @default(uuid())
  workspaceId       String
  userId            String
  frequency         DigestFrequency  @default(WEEKLY)
  enabled           Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  workspace         Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId, frequency])
  @@index([workspaceId])
  @@index([userId])
}

model DigestRun {
  id                String   @id @default(uuid())
  workspaceId       String
  summary           Json?
  sentAt            DateTime @default(now())

  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([sentAt])
}

model UploadAsset {
  id                String   @id @default(uuid())
  workspaceId       String
  fileName          String
  s3Key             String
  s3Bucket          String
  mimeType          String
  sizeBytes         Int
  createdAt         DateTime @default(now())

  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model AiJobLog {
  id                String      @id @default(uuid())
  workspaceId       String
  jobType           AiJobType
  status            AiJobStatus @default(QUEUED)
  entityType        String?
  entityId          String?
  input             Json?
  output            Json?
  error             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  workspace         Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([jobType])
  @@index([status])
}

model AuditLog {
  id                String         @id @default(uuid())
  workspaceId       String
  userId            String?
  action            AuditLogAction
  details           Json
  createdAt         DateTime       @default(now())

  workspace         Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user              User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
model WorkspaceInvite {
  id          String        @id @default(uuid())
  workspaceId String
  email       String
  /// Pre-filled first name for the invitee — used to populate User.firstName on accept
  firstName   String?
  /// Pre-filled last name for the invitee — used to populate User.lastName on accept
  lastName    String?
  /// Job title / position for the invitee — stored on WorkspaceMember on accept
  position    String?
  role        WorkspaceRole @default(VIEWER)
  token       String        @unique @default(uuid())
  invitedById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime      @default(now())

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy   User          @relation("InvitedByUser", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([token])
}

/// ── Plan Configuration ────────────────────────────────────────────────────
/// Managed exclusively by SUPER_ADMIN via /platform/plans endpoints.
/// Each row defines the limits and feature flags for one BillingPlan tier.
///
/// Plans: FREE | PRO ($29/mo) | BUSINESS ($49/mo)
model Plan {
  id                  String      @id @default(uuid())
  /// Matches the BillingPlan enum value (unique — one config row per plan)
  planType            BillingPlan @unique
  displayName         String
  description         String?
  /// Monthly price in USD cents (0 = free)
  priceMonthly        Int         @default(0)
  /// Trial duration in days (0 = no trial)
  trialDays           Int         @default(0)
  /// Max number of ADMIN-role members allowed (null = unlimited)
  adminLimit          Int?        @default(1)
  /// Total staff seat limit including admins (null = unlimited)
  seatLimit           Int?
  /// Monthly AI inference calls allowed (null = unlimited)
  aiUsageLimit        Int?
  /// Monthly feedback items allowed (null = unlimited)
  feedbackLimit       Int?
  /// Monthly voice upload slots (0 = disabled, null = unlimited)
  voiceUploadLimit    Int         @default(0)
  /// Monthly survey response slots (0 = disabled, null = unlimited)
  surveyResponseLimit Int         @default(0)
  /// Feature flags
  aiInsights          Boolean     @default(false)
  aiThemeClustering   Boolean     @default(false)
  ciqPrioritization   Boolean     @default(false)
  explainableAi       Boolean     @default(false)
  weeklyDigest        Boolean     @default(false)
  voiceFeedback       Boolean     @default(false)
  survey              Boolean     @default(false)
  integrations        Boolean     @default(false)
  publicPortal        Boolean     @default(true)
  csvImport           Boolean     @default(true)
  apiAccess           Boolean     @default(false)
  executiveReporting  Boolean     @default(false)
  /// Custom domain — coming soon; always false for now
  customDomain        Boolean     @default(false)
  /// Whether this plan is offered to new signups
  isActive            Boolean     @default(true)
  /// Whether this is the default plan assigned on signup when no plan is chosen
  isDefault           Boolean     @default(false)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}
