# ─────────────────────────────────────────────────────────────────────────────
# .env.production
#
# Copy this file to /home/ubuntu/triage-insight/.env.production on the
# Lightsail instance. Fill in every CHANGE_ME value before first deploy.
#
# !! NEVER commit this file with real values to git !!
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── API port ──────────────────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL (self-hosted in Docker on the same box) ────────────────────────
# These match the postgres service in docker-compose.production.yml.
# The host is the Docker service name "postgres" (internal DNS).
POSTGRES_USER=triage
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=triageinsight
DATABASE_URL=postgresql://triage:CHANGE_ME_STRONG_DB_PASSWORD@postgres:5432/triageinsight?schema=public

# ── Redis (self-hosted in Docker on the same box) ─────────────────────────────
# The host is the Docker service name "redis" (internal DNS).
REDIS_HOST=redis
REDIS_PORT=6379
# REDIS_PASSWORD=   # Leave blank unless you add requirepass to redis command

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_CHAR_MINIMUM_SECRET_KEY

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your CloudFront domain or custom domain pointing to CloudFront
CORS_ORIGIN=https://app.yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ── AWS (for S3 file uploads and SES email) ───────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET
AWS_S3_BUCKET=triage-insight-uploads-prod

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=ses
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_ADDRESS=noreply@yourdomain.com

# ── Stripe (optional for pilot) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── BullMQ job tuning ─────────────────────────────────────────────────────────
JOB_MAX_ATTEMPTS=5
JOB_BACKOFF_DELAY_MS=2000
JOB_REMOVE_ON_COMPLETE=1000
JOB_REMOVE_ON_FAIL=5000

# ── Next.js Web ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are baked into the Docker image at build time via ARG.
# Set them as GitHub Actions secrets, not here.
# NEXT_PUBLIC_API_BASE_URL=https://app.yourdomain.com/api/v1
