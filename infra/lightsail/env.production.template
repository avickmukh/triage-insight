# ─────────────────────────────────────────────────────────────────────────────
# .env.production  (copy to /home/ubuntu/triage-insight/.env.production)
#
# !! NEVER commit this file with real values !!
# This template shows every variable the application needs in production.
# Fill in the values from your AWS console and service dashboards.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── API port (NestJS) ─────────────────────────────────────────────────────────
PORT=3000

# ── PostgreSQL (Lightsail Managed Database) ───────────────────────────────────
# Find in: Lightsail console → Databases → your-db → Connect tab
# Format:  postgresql://USER:PASSWORD@ENDPOINT:5432/DBNAME?schema=public
DATABASE_URL=postgresql://triage:CHANGE_ME@ls-xxxx.us-east-1.rds.amazonaws.com:5432/triageinsight?schema=public

# ── Redis (Lightsail Managed Redis Cache) ─────────────────────────────────────
# Find in: Lightsail console → Databases → your-cache → Connect tab
# Use the primary endpoint (no port suffix needed for REDIS_URL)
REDIS_HOST=ls-xxxx.cache.amazonaws.com
REDIS_PORT=6379
# REDIS_PASSWORD=          # Set if your Redis cluster has AUTH enabled
# REDIS_TLS=true           # Lightsail Redis uses TLS — set to true

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_32_CHAR_MINIMUM_SECRET_KEY

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your CloudFront web URL (or custom domain)
CORS_ORIGIN=https://app.yourdomain.com

# ── Rate Limiting ─────────────────────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100

# ── AWS (for S3 uploads, SES email, CloudFront) ───────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_S3_BUCKET=triage-insight-uploads-prod

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Email ─────────────────────────────────────────────────────────────────────
# Options: console | smtp | ses
EMAIL_PROVIDER=ses
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM_ADDRESS=noreply@yourdomain.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Job Tuning ────────────────────────────────────────────────────────────────
JOB_MAX_ATTEMPTS=5
JOB_BACKOFF_DELAY_MS=2000
JOB_REMOVE_ON_COMPLETE=1000
JOB_REMOVE_ON_FAIL=5000

# ── Next.js Web (baked into the Docker image at build time via ARG) ───────────
# These are here for reference — they are passed as --build-arg in CI, not
# read at runtime from this file.
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api/v1
